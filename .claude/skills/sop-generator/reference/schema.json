{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "流程节点配置",
  "description": "定义流程节点和连线的结构化数据规范",
  "type": "object",
  "required": ["nodes", "edges"],
  "properties": {
    "nodes": {
      "description": "SOP节点列表",
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type", "name", "desc", "input", "output", "businessLogics", "completeCondition"],
        "properties": {
          "id": {
            "description": "节点唯一标识",
            "type": "string",
            "pattern": "^[N0-9]+$"
          },
          "type": {
            "description": "节点类型",
            "type": "string",
            "enum": ["start", "task", "end"]
          },
          "name": {
            "description": "节点名称",
            "type": "string",
            "minLength": 1
          },
          "desc": {
            "description": "节点任务描述",
            "type": "string"
          },
          "input": {
            "type": "object",
            "properties": {
              "desc": {
                "description": "节点输入信息描述",
                "type": "string"
              }
            }
          },
          "output": {
            "type": "object",
            "properties": {
              "desc": {
                "description": "节点输出信息描述",
                "type": "string"
              }
            }
          },
          "businessLogics": {
            "description": "节点业务逻辑步骤",
            "type": "string"
          },
          "completeCondition": {
            "type": "object",
            "required": ["businessRule"],
            "properties": {
              "businessRule": {
                "description": "节点完成条件的内容描述",
                "type": "string"
              }
            }
          }
        },
        "if": {
          "properties": {
            "type": {
              "enum": ["start", "end"]
            }
          }
        },
        "then": {
          "additionalProperties": false,
          "properties": {
            "id": true,
            "type": true,
            "name": true
          }
        }
      }
    },
    "edges": {
      "description": "节点连线列表",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source", "target"],
        "properties": {
          "source": {
            "description": "起始节点ID",
            "type": "string"
          },
          "target": {
            "description": "目标节点ID",
            "type": "string"
          }
        }
      }
    }
  }
}