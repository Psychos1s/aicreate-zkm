{
    "cards": {
        "DocumentDownloadCard": {
            "code": "DocumentDownloadCard",
            "version": "0.x",
            "description": "单文件下载卡片。当用户需要下载文件、导出文档、获取模板时使用。args 必须包含 fileUrl(string)、fileName(string) 两个标量字段，可选 fileSize(number)。严禁使用 files/fileList/attachments 等数组或嵌套结构。",
            "required_args": {
                "fileUrl": "string - 文件下载地址（必须是完整 URL 字符串）",
                "fileName": "string - 文件名称（含扩展名，如 '报告.pdf'）"
            },
            "optional_args": {
                "fileSize": "number - 文件大小(字节)"
            },
            "forbidden_args": {
                "files": "❌ 禁止。不支持数组结构，必须用 fileUrl/fileName 标量字段",
                "fileList": "❌ 禁止。同上",
                "attachments": "❌ 禁止。同上"
            },
            "examples": [
                {
                    "name": "✅ 正确：带文件大小",
                    "args": {
                        "fileUrl": "https://example.com/report.pdf",
                        "fileName": "年度报告.pdf",
                        "fileSize": 467634
                    }
                },
                {
                    "name": "✅ 正确：不带文件大小",
                    "args": {
                        "fileUrl": "https://example.com/template.docx",
                        "fileName": "模板.docx"
                    }
                }
            ]
        },
        "DynamicForm": {
            "code": "DynamicForm",
            "version": "0.x",
            "description": "动态表单卡片，当需要收集用户输入、填写信息、提交数据时使用。通过 formSchema 描述表单结构。",
            "required_args": {
                "cardMode": "boolean - 固定为 true",
                "title": "string - 卡片标题，描述表单用途（如'客户信息收集'）",
                "formSchema": "Array<FieldSchema> - 表单字段定义数组"
            },
            "field_schema": {
                "required_field_props": {
                    "label": "string - 字段显示名称（⚠️ 不要用 title）",
                    "type": "string - 字段类型",
                    "key": "string - 字段唯一标识"
                },
                "optional_field_props": {
                    "required": "boolean - 是否必填",
                    "defaultValue": "any - 默认值",
                    "description": "string - 字段说明/占位提示",
                    "x-validator": "Array - 校验规则",
                    "x-reactions": "Array - 联动规则",
                    "dataSource": "Array<{label, value}> - 选项数据源（select/multi-select 专用，value 不能重复）",
                    "layoutProps": "object - 布局配置（groupId/groupName，仅需分组时添加）"
                },
                "supported_types": [
                    "input-text",
                    "textarea",
                    "number",
                    "select",
                    "multi-select",
                    "switch",
                    "input-date",
                    "input-time",
                    "datetime",
                    "uploader",
                    "markdown",
                    "link",
                    "array-tabs"
                ],
                "forbidden_field_props": {
                    "title": "❌ 禁止。字段显示名称必须用 label",
                    "enum": "❌ 禁止。选项列表必须用 dataSource: [{label, value}]",
                    "enumNames": "❌ 禁止。选项列表必须用 dataSource: [{label, value}]"
                }
            },
            "examples": [
                {
                    "name": "收集基本信息",
                    "args": {
                        "cardMode": true,
                        "title": "客户基本信息",
                        "formSchema": [
                            {
                                "label": "姓名",
                                "type": "input-text",
                                "key": "name",
                                "required": true
                            },
                            {
                                "label": "所属行业",
                                "type": "select",
                                "key": "industry",
                                "required": true,
                                "dataSource": [
                                    { "label": "制造业", "value": "制造业" },
                                    { "label": "金融行业", "value": "金融行业" },
                                    { "label": "信息技术", "value": "信息技术" }
                                ]
                            },
                            {
                                "label": "备注",
                                "type": "textarea",
                                "key": "remark",
                                "required": false,
                                "description": "可选补充说明"
                            }
                        ]
                    }
                }
            ]
        }
    }
}
